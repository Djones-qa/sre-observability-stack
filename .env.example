# ─────────────────────────────────────────────────────────────
# SRE Observability Platform — Environment Variables
# Copy to .env and adjust before running docker compose up
# ─────────────────────────────────────────────────────────────

# Redis connection URL (used by all three services)
REDIS_URL=redis://redis:6379

# ── metrics-aggregator (port 4000) ──────────────────────────
METRICS_PORT=4000
# Default scrape interval in seconds for newly registered targets
SCRAPE_DEFAULT_INTERVAL_S=15
# HTTP timeout for scrape requests in milliseconds
SCRAPE_TIMEOUT_MS=10000
# Default SLO target (0.0 – 1.0). 0.999 = 99.9% availability
DEFAULT_SLO_TARGET=0.999

# ── log-pipeline (port 4001) ────────────────────────────────
LOG_PORT=4001
# Max entries in the logs:all Redis Stream (approx, uses ~ cap)
LOG_MAX_STREAM_LENGTH=1000000
# Max entries in the logs:errors Redis Stream
LOG_ERROR_MAX_STREAM_LENGTH=100000

# ── slo-dashboard-api (port 4002) ───────────────────────────
DASHBOARD_PORT=4002
# Default number of log entries returned by /logs/:service/errors
LOG_QUERY_DEFAULT_LIMIT=50
# Maximum number of log entries that can be requested
LOG_QUERY_MAX_LIMIT=500
